        <ImplicitUsings>enable</ImplicitUsings>
      <UserSecretsId>e72c20d7-4a99-4afb-9f85-0d9290525344</UserSecretsId>
  </PropertyGroup>

    <ItemGroup>
      <PackageReference Include="Microsoft.EntityFrameworkCore" Version="10.0.3" />
